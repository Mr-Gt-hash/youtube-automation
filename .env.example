# ─────────────────────────────────────────────────────────
# YouTube Automation Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── ElevenLabs (optional, gTTS used as fallback) ──────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── YouTube OAuth 2.0 ─────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Pexels (free B-roll footage) ──────────────────────────
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Notifications ─────────────────────────────────────────
SLACK_WEBHOOK_URL=
ALERT_EMAIL=you@example.com

# ── Pipeline Settings ─────────────────────────────────────
TARGET_NICHE=technology
VIDEOS_PER_DAY=1
UPLOAD_TIME=17:00
VIDEO_LANGUAGE=en
MAX_VIDEO_DURATION=600
VIDEO_CATEGORY_ID=28
